# Community app env. Copy to .env.local for local dev.
# None of these values are required for Step 1 (landing only). Step 2
# wires X OAuth and will require the AUTH_* entries.

# Site URL — used for OAuth callback construction in Step 2.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Backend (shared with main app). Points / task state land here.
NEXT_PUBLIC_BACKEND_URL=https://api.dogeforge.fun

# --- X OAuth 2.0 (Step 2) ---
# Get from https://developer.x.com → your app → OAuth 2.0 settings.
# Callback URL configured on the X side must exactly match this site's
# /api/auth/callback/twitter path.
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=
AUTH_SECRET=

# --- WalletConnect (Step 2) ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
